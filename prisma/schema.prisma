generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js 必須モデル ────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Google OAuth のみ使用するため実際には使われないが、Adapter が型として要求する
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── ドメインモデル ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  name          String?
  // Auth.js の PrismaAdapter がユーザー作成時に必須とするフィールド
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  accounts           Account[]
  sessions           Session[]
  teamMemberships    TeamMember[]
  attendances        Attendance[]
  helperApplications HelperApplication[]
}

model Team {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  inviteCode  String   @unique
  createdById String
  createdAt   DateTime @default(now())

  // 連絡先（すべて任意・チーム詳細ページで一般公開される）
  twitterUrl   String?
  instagramUrl String?
  contactEmail String?

  members        TeamMember[]
  games          Game[]
  helperRequests HelperRequest[]
  memberRequests MemberRequest[]
  groundOffers   GroundOffer[]
  matchRequests  MatchRequest[]
}

// 試合結果（自チームスコアと相手スコアから自動計算する）
enum GameResult {
  WIN
  LOSE
  DRAW
}

model Game {
  id          String   @id @default(cuid())
  teamId      String
  startsAt    DateTime // 試合日時
  location    String // 場所
  meetTime    String // 集合時間（"HH:mm" 形式）
  startTime   String // 試合開始時間（"HH:mm" 形式。集合時間とは別に管理する）
  capacity    Int? // 定員（任意）
  note        String?  @db.Text // メモ（任意）
  createdById String
  createdAt   DateTime @default(now())

  // 試合結果（任意・管理者が試合後に入力する）
  opponentName   String? // 対戦相手名
  ourScore       Int? // 自チームスコア
  opponentScore  Int? // 相手スコア
  tournamentName String? // 大会名（任意）
  summary        String?     @db.Text // 戦評（任意）
  result         GameResult? // ourScore/opponentScore から自動計算される

  team           Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  attendances    Attendance[]
  helperRequests HelperRequest[]

  @@index([teamId])
}

enum TeamRole {
  ADMIN
  PLAYER
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     TeamRole @default(PLAYER)
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

// 出欠の回答状態
enum AttendanceStatus {
  ATTENDING // 参加
  ABSENT // 欠席
  UNDECIDED // 未定
}

// 試合ごと・ユーザーごとの出欠回答（1試合につき1ユーザー1件）
model Attendance {
  id        String           @id @default(cuid())
  gameId    String
  userId    String
  status    AttendanceStatus
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gameId, userId])
  @@index([gameId])
  @@index([userId])
}

// 助っ人募集の状態
enum HelperRequestStatus {
  OPEN // 募集中
  CLOSED // 募集終了
}

// 試合ごとの助っ人募集（管理者が作成）
model HelperRequest {
  id           String              @id @default(cuid())
  gameId       String
  teamId       String
  createdById  String
  positions    String? // 募集ポジション（任意・自由記述）
  count        Int                 @default(1) // 募集人数
  note         String?             @db.Text // メモ（任意）
  contactEmail String // 代表者メールアドレス（連絡先・必須）
  prefecture   String              @default("東京都") // 都道府県（地域絞り込み用・必須）
  status       HelperRequestStatus @default(OPEN)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  game         Game                @relation(fields: [gameId], references: [id], onDelete: Cascade)
  team         Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  applications HelperApplication[]

  @@index([gameId])
  @@index([teamId])
}

// 助っ人募集への応募（チーム外ユーザーが応募する。1募集につき1ユーザー1件）
model HelperApplication {
  id              String   @id @default(cuid())
  helperRequestId String
  userId          String
  createdAt       DateTime @default(now())

  helperRequest HelperRequest @relation(fields: [helperRequestId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([helperRequestId, userId])
  @@index([helperRequestId])
  @@index([userId])
}

// メンバー募集の状態
enum MemberRequestStatus {
  OPEN // 募集中
  CLOSED // 募集終了
}

// チームのメンバー募集（管理者が作成）
model MemberRequest {
  id           String              @id @default(cuid())
  teamId       String
  createdById  String
  positions    String? // 募集ポジション（任意・自由記述）
  count        Int                 @default(1) // 募集人数
  level        String? // レベル感（任意・例：初心者歓迎、中級者以上など）
  note         String?             @db.Text // メモ（任意）
  contactEmail String // 代表者メールアドレス（連絡先・必須）
  prefecture   String              @default("東京都") // 都道府県（地域絞り込み用・必須）
  status       MemberRequestStatus @default(OPEN)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

// グラウンド譲渡の状態
enum GroundOfferStatus {
  OPEN // 募集中
  CLOSED // 募集終了
}

// チームのグラウンド譲渡（管理者が作成）
model GroundOffer {
  id           String            @id @default(cuid())
  teamId       String
  createdById  String
  groundName   String // グラウンド名（必須）
  location     String // 場所・住所（必須）
  date         DateTime // 譲渡希望日時（必須）
  capacity     Int? // 収容人数（任意）
  note         String?           @db.Text // メモ（任意）
  contactEmail String // 代表者メールアドレス（連絡先・必須）
  prefecture   String            @default("東京都") // 都道府県（地域絞り込み用・必須）
  status       GroundOfferStatus @default(OPEN)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

// 対戦相手募集の状態
enum MatchRequestStatus {
  OPEN // 募集中
  CLOSED // 募集終了
}

// チームの対戦相手募集（管理者が作成）
model MatchRequest {
  id           String             @id @default(cuid())
  teamId       String
  createdById  String
  date         DateTime // 試合希望日時（必須）
  location     String? // 希望場所（任意）
  level        String? // レベル感（任意・例：初心者歓迎、中級者以上など）
  memberCount  Int? // 参加予定人数（任意）
  note         String?            @db.Text // メモ（任意）
  contactEmail String // 代表者メールアドレス（連絡先・必須）
  prefecture   String             @default("東京都") // 都道府県（地域絞り込み用・必須）
  status       MatchRequestStatus @default(OPEN)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
}
