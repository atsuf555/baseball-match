generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js 必須モデル ────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Google OAuth のみ使用するため実際には使われないが、Adapter が型として要求する
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── ドメインモデル ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  name          String?
  // Auth.js の PrismaAdapter がユーザー作成時に必須とするフィールド
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  accounts        Account[]
  sessions        Session[]
  teamMemberships TeamMember[]
  attendances     Attendance[]
}

model Team {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  inviteCode  String   @unique
  createdById String
  createdAt   DateTime @default(now())

  members TeamMember[]
  games   Game[]
}

model Game {
  id          String   @id @default(cuid())
  teamId      String
  startsAt    DateTime // 試合日時
  location    String // 場所
  meetTime    String // 集合時間（"HH:mm" 形式）
  startTime   String // 試合開始時間（"HH:mm" 形式。集合時間とは別に管理する）
  capacity    Int? // 定員（任意）
  note        String?  @db.Text // メモ（任意）
  createdById String
  createdAt   DateTime @default(now())

  team        Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  attendances Attendance[]

  @@index([teamId])
}

enum TeamRole {
  ADMIN
  PLAYER
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     TeamRole @default(PLAYER)
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

// 出欠の回答状態
enum AttendanceStatus {
  ATTENDING // 参加
  ABSENT // 欠席
  UNDECIDED // 未定
}

// 試合ごと・ユーザーごとの出欠回答（1試合につき1ユーザー1件）
model Attendance {
  id        String           @id @default(cuid())
  gameId    String
  userId    String
  status    AttendanceStatus
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gameId, userId])
  @@index([gameId])
  @@index([userId])
}
